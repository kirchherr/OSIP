{
  "components": {
    "schemas": {
      "ActionPriority": {
        "enum": [
          "low",
          "normal",
          "high",
          "critical"
        ],
        "type": "string"
      },
      "ActionProposal": {
        "additionalProperties": false,
        "properties": {
          "action_id": {
            "$ref": "#/components/schemas/Label"
          },
          "based_on_context": {
            "minLength": 1,
            "title": "Based On Context",
            "type": "string"
          },
          "confidence": {
            "$ref": "#/components/schemas/Confidence"
          },
          "correlation_id": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TraceIdentifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "deadline_ms": {
            "$ref": "#/components/schemas/PositiveInt"
          },
          "priority": {
            "$ref": "#/components/schemas/ActionPriority"
          },
          "proposal_id": {
            "minLength": 1,
            "title": "Proposal Id",
            "type": "string"
          },
          "reason": {
            "minLength": 1,
            "title": "Reason",
            "type": "string"
          },
          "requires_confirmation": {
            "title": "Requires Confirmation",
            "type": "boolean"
          },
          "schema_version": {
            "const": "osip/0.1",
            "default": "osip/0.1",
            "title": "Schema Version",
            "type": "string"
          },
          "trace_id": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TraceIdentifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "type": {
            "const": "action.proposal",
            "default": "action.proposal",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "proposal_id",
          "based_on_context",
          "action_id",
          "priority",
          "confidence",
          "deadline_ms",
          "reason",
          "requires_confirmation"
        ],
        "title": "ActionProposal",
        "type": "object"
      },
      "Claim": {
        "additionalProperties": false,
        "properties": {
          "confidence": {
            "$ref": "#/components/schemas/Confidence"
          },
          "label": {
            "$ref": "#/components/schemas/Label"
          },
          "uncertainty": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Uncertainty"
              },
              {
                "type": "null"
              }
            ]
          },
          "value": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              },
              {
                "type": "string"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Value"
          }
        },
        "required": [
          "label",
          "confidence"
        ],
        "title": "Claim",
        "type": "object"
      },
      "Confidence": {
        "maximum": 1.0,
        "minimum": 0.0,
        "type": "number"
      },
      "ContextEntity": {
        "additionalProperties": false,
        "properties": {
          "confidence": {
            "$ref": "#/components/schemas/Confidence"
          },
          "id": {
            "minLength": 1,
            "title": "Id",
            "type": "string"
          },
          "state": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "type": {
            "$ref": "#/components/schemas/Identifier"
          },
          "uncertainty": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Uncertainty"
              },
              {
                "type": "null"
              }
            ]
          },
          "zone": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "id",
          "type",
          "confidence"
        ],
        "title": "ContextEntity",
        "type": "object"
      },
      "ContextEvent": {
        "additionalProperties": false,
        "properties": {
          "confidence": {
            "$ref": "#/components/schemas/Confidence"
          },
          "contradiction_refs": {
            "items": {
              "$ref": "#/components/schemas/EvidenceRef"
            },
            "title": "Contradiction Refs",
            "type": "array"
          },
          "contradictions": {
            "items": {
              "$ref": "#/components/schemas/Label"
            },
            "title": "Contradictions",
            "type": "array"
          },
          "evidence": {
            "items": {
              "$ref": "#/components/schemas/Label"
            },
            "minItems": 1,
            "title": "Evidence",
            "type": "array"
          },
          "evidence_refs": {
            "items": {
              "$ref": "#/components/schemas/EvidenceRef"
            },
            "title": "Evidence Refs",
            "type": "array"
          },
          "label": {
            "$ref": "#/components/schemas/Label"
          },
          "uncertainty": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Uncertainty"
              },
              {
                "type": "null"
              }
            ]
          },
          "urgency": {
            "$ref": "#/components/schemas/Confidence"
          }
        },
        "required": [
          "label",
          "confidence",
          "urgency",
          "evidence"
        ],
        "title": "ContextEvent",
        "type": "object"
      },
      "ContextGraphStats": {
        "additionalProperties": false,
        "description": "Small graph summary for diagnostics and benchmark reports.",
        "properties": {
          "rooms": {
            "items": {
              "type": "string"
            },
            "title": "Rooms",
            "type": "array"
          },
          "total_entities": {
            "minimum": 0.0,
            "title": "Total Entities",
            "type": "integer"
          },
          "total_events": {
            "minimum": 0.0,
            "title": "Total Events",
            "type": "integer"
          },
          "total_updates": {
            "minimum": 0.0,
            "title": "Total Updates",
            "type": "integer"
          }
        },
        "required": [
          "total_updates",
          "total_entities",
          "total_events"
        ],
        "title": "ContextGraphStats",
        "type": "object"
      },
      "ContextUpdate": {
        "additionalProperties": false,
        "properties": {
          "context_id": {
            "minLength": 1,
            "title": "Context Id",
            "type": "string"
          },
          "correlation_id": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TraceIdentifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "entities": {
            "items": {
              "$ref": "#/components/schemas/ContextEntity"
            },
            "title": "Entities",
            "type": "array"
          },
          "events": {
            "items": {
              "$ref": "#/components/schemas/ContextEvent"
            },
            "title": "Events",
            "type": "array"
          },
          "global_risk": {
            "$ref": "#/components/schemas/GlobalRisk"
          },
          "room": {
            "$ref": "#/components/schemas/Identifier"
          },
          "schema_version": {
            "const": "osip/0.1",
            "default": "osip/0.1",
            "title": "Schema Version",
            "type": "string"
          },
          "time_window_ms": {
            "$ref": "#/components/schemas/PositiveInt"
          },
          "timestamp": {
            "format": "date-time",
            "title": "Timestamp",
            "type": "string"
          },
          "trace_id": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TraceIdentifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "type": {
            "const": "context.update",
            "default": "context.update",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "context_id",
          "timestamp",
          "time_window_ms",
          "room",
          "global_risk"
        ],
        "title": "ContextUpdate",
        "type": "object"
      },
      "CovarianceMatrix": {
        "additionalProperties": false,
        "properties": {
          "unit": {
            "anyOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Unit"
          },
          "values": {
            "items": {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            "minItems": 1,
            "title": "Values",
            "type": "array"
          },
          "variables": {
            "items": {
              "$ref": "#/components/schemas/Identifier"
            },
            "minItems": 1,
            "title": "Variables",
            "type": "array"
          }
        },
        "required": [
          "variables",
          "values"
        ],
        "title": "CovarianceMatrix",
        "type": "object"
      },
      "DashboardCounters": {
        "additionalProperties": false,
        "description": "Runtime counters exposed to dashboards and demos.",
        "properties": {
          "action_proposals_emitted": {
            "minimum": 0.0,
            "title": "Action Proposals Emitted",
            "type": "integer"
          },
          "contexts_emitted": {
            "minimum": 0.0,
            "title": "Contexts Emitted",
            "type": "integer"
          },
          "model_plugins_registered": {
            "minimum": 0.0,
            "title": "Model Plugins Registered",
            "type": "integer"
          },
          "models_registered": {
            "minimum": 0.0,
            "title": "Models Registered",
            "type": "integer"
          },
          "percepts_ingested": {
            "minimum": 0.0,
            "title": "Percepts Ingested",
            "type": "integer"
          }
        },
        "required": [
          "models_registered",
          "model_plugins_registered",
          "percepts_ingested",
          "contexts_emitted",
          "action_proposals_emitted"
        ],
        "title": "DashboardCounters",
        "type": "object"
      },
      "DashboardSnapshot": {
        "additionalProperties": false,
        "description": "Machine-readable dashboard state for local demos and tests.",
        "properties": {
          "context_graph": {
            "$ref": "#/components/schemas/ContextGraphStats"
          },
          "counters": {
            "$ref": "#/components/schemas/DashboardCounters"
          },
          "current_context": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ContextUpdate"
              },
              {
                "type": "null"
              }
            ]
          },
          "generated_at": {
            "format": "date-time",
            "title": "Generated At",
            "type": "string"
          },
          "recent_action_proposals": {
            "items": {
              "$ref": "#/components/schemas/ActionProposal"
            },
            "title": "Recent Action Proposals",
            "type": "array"
          },
          "recent_percept_latency_ms": {
            "$ref": "#/components/schemas/LatencySummary"
          },
          "recent_percepts": {
            "items": {
              "$ref": "#/components/schemas/PerceptPacket"
            },
            "title": "Recent Percepts",
            "type": "array"
          },
          "registered_models": {
            "items": {
              "type": "string"
            },
            "title": "Registered Models",
            "type": "array"
          },
          "registered_plugins": {
            "items": {
              "type": "string"
            },
            "title": "Registered Plugins",
            "type": "array"
          }
        },
        "required": [
          "generated_at",
          "counters",
          "context_graph",
          "recent_percept_latency_ms"
        ],
        "title": "DashboardSnapshot",
        "type": "object"
      },
      "EmbeddingCapability": {
        "additionalProperties": false,
        "properties": {
          "available": {
            "title": "Available",
            "type": "boolean"
          },
          "dimension": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PositiveInt"
              },
              {
                "type": "null"
              }
            ]
          },
          "space": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "available"
        ],
        "title": "EmbeddingCapability",
        "type": "object"
      },
      "EmbeddingRef": {
        "additionalProperties": false,
        "properties": {
          "dimension": {
            "$ref": "#/components/schemas/PositiveInt"
          },
          "ref": {
            "minLength": 1,
            "title": "Ref",
            "type": "string"
          },
          "space": {
            "$ref": "#/components/schemas/Identifier"
          }
        },
        "required": [
          "ref",
          "dimension",
          "space"
        ],
        "title": "EmbeddingRef",
        "type": "object"
      },
      "EvidenceRef": {
        "additionalProperties": false,
        "description": "Structured reference to the source evidence behind a context event.",
        "properties": {
          "claim_label": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Label"
              },
              {
                "type": "null"
              }
            ]
          },
          "confidence": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Confidence"
              },
              {
                "type": "null"
              }
            ]
          },
          "modality": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "source_id": {
            "minLength": 1,
            "title": "Source Id",
            "type": "string"
          },
          "source_model": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "source_type": {
            "$ref": "#/components/schemas/EvidenceSourceType"
          },
          "timestamp": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp"
          }
        },
        "required": [
          "source_type",
          "source_id"
        ],
        "title": "EvidenceRef",
        "type": "object"
      },
      "EvidenceSourceType": {
        "enum": [
          "percept.packet",
          "context.update",
          "event.detected",
          "action.result",
          "external"
        ],
        "type": "string"
      },
      "GlobalRisk": {
        "additionalProperties": false,
        "properties": {
          "comfort": {
            "$ref": "#/components/schemas/Confidence"
          },
          "maintenance": {
            "$ref": "#/components/schemas/Confidence"
          },
          "safety": {
            "$ref": "#/components/schemas/Confidence"
          }
        },
        "required": [
          "safety",
          "comfort",
          "maintenance"
        ],
        "title": "GlobalRisk",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "Identifier": {
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)*(_v[0-9]+)?$",
        "type": "string"
      },
      "Label": {
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$",
        "type": "string"
      },
      "LatencyProfile": {
        "additionalProperties": false,
        "properties": {
          "max_budget_ms": {
            "$ref": "#/components/schemas/PositiveInt"
          },
          "p50_ms": {
            "$ref": "#/components/schemas/PositiveInt"
          },
          "p95_ms": {
            "$ref": "#/components/schemas/PositiveInt"
          }
        },
        "required": [
          "p50_ms",
          "p95_ms",
          "max_budget_ms"
        ],
        "title": "LatencyProfile",
        "type": "object"
      },
      "LatencySummary": {
        "additionalProperties": false,
        "description": "Latency summary for recent percept ingestion.",
        "properties": {
          "avg_ms": {
            "anyOf": [
              {
                "minimum": 0.0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Avg Ms"
          },
          "count": {
            "minimum": 0.0,
            "title": "Count",
            "type": "integer"
          },
          "max_ms": {
            "anyOf": [
              {
                "minimum": 0.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Ms"
          },
          "min_ms": {
            "anyOf": [
              {
                "minimum": 0.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Min Ms"
          }
        },
        "required": [
          "count"
        ],
        "title": "LatencySummary",
        "type": "object"
      },
      "Location": {
        "additionalProperties": false,
        "properties": {
          "azimuth_deg": {
            "anyOf": [
              {
                "maximum": 180.0,
                "minimum": -180.0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Azimuth Deg"
          },
          "coordinates": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "number"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Coordinates"
          },
          "room": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "uncertainty": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Uncertainty"
              },
              {
                "type": "null"
              }
            ]
          },
          "zone": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "title": "Location",
        "type": "object"
      },
      "ModelCapabilityDescriptor": {
        "additionalProperties": false,
        "properties": {
          "confidence_calibrated": {
            "title": "Confidence Calibrated",
            "type": "boolean"
          },
          "correlation_id": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TraceIdentifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "display_name": {
            "minLength": 1,
            "title": "Display Name",
            "type": "string"
          },
          "embedding": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/EmbeddingCapability"
              },
              {
                "type": "null"
              }
            ]
          },
          "latency_profile": {
            "$ref": "#/components/schemas/LatencyProfile"
          },
          "modalities": {
            "items": {
              "$ref": "#/components/schemas/Identifier"
            },
            "minItems": 1,
            "title": "Modalities",
            "type": "array"
          },
          "model_id": {
            "$ref": "#/components/schemas/Identifier"
          },
          "outputs": {
            "items": {
              "$ref": "#/components/schemas/Label"
            },
            "minItems": 1,
            "title": "Outputs",
            "type": "array"
          },
          "schema_version": {
            "const": "osip/0.1",
            "default": "osip/0.1",
            "title": "Schema Version",
            "type": "string"
          },
          "spatial_reference": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Identifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "trace_id": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TraceIdentifier"
              },
              {
                "type": "null"
              }
            ]
          },
          "type": {
            "const": "model.capability",
            "default": "model.capability",
            "title": "Type",
            "type": "string"
          },
          "version": {
            "minLength": 1,
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "model_id",
          "display_name",
          "version",
          "modalities",
          "outputs",
          "latency_profile",
          "confidence_calibrated"
        ],
        "title": "ModelCapabilityDescriptor",
        "type": "object"
      },
      "ModelPluginManifest": {
        "additionalProperties": false,
        "description": "Declarative contract for one model plug-in and its OSIP capability.",
        "properties": {
          "application_profiles": {
            "items": {
              "$ref": "#/components/schemas/ProfileIdentifier"
            },
            "title": "Application Profiles",
            "type": "array"
          },
          "capability": {
            "$ref": "#/components/schemas/ModelCapabilityDescriptor"
          },
          "display_name": {
            "minLength": 1,
            "title": "Display Name",
            "type": "string"
          },
          "entrypoint": {
            "anyOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Entrypoint"
          },
          "license": {
            "anyOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "License"
          },
          "metadata": {
            "additionalProperties": true,
            "title": "Metadata",
            "type": "object"
          },
          "plugin_id": {
            "$ref": "#/components/schemas/Identifier"
          },
          "requires_hardware": {
            "default": false,
            "title": "Requires Hardware",
            "type": "boolean"
          },
          "runtime": {
            "$ref": "#/components/schemas/PluginRuntime",
            "default": "simulation_stub"
          },
          "sandbox_required": {
            "default": true,
            "title": "Sandbox Required",
            "type": "boolean"
          },
          "schema_version": {
            "const": "model_plugin/0.1",
            "default": "model_plugin/0.1",
            "title": "Schema Version",
            "type": "string"
          },
          "source_uri": {
            "anyOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Uri"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "title": "Tags",
            "type": "array"
          },
          "version": {
            "minLength": 1,
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "plugin_id",
          "display_name",
          "version",
          "capability"
        ],
        "title": "ModelPluginManifest",
        "type": "object"
      },
      "ModelPluginRegistrationResponse": {
        "additionalProperties": false,
        "properties": {
          "model_id": {
            "title": "Model Id",
            "type": "string"
          },
          "plugin_id": {
            "title": "Plugin Id",
            "type": "string"
          },
          "registered": {
            "title": "Registered",
            "type": "boolean"
