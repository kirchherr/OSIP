      },
      "messages": [
        {
          "$ref": "#/channels/profileSafetyCases/messages/profileSafetyCase"
        }
      ]
    },
    "subscribeActionCommands": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/actionCommands"
      },
      "messages": [
        {
          "$ref": "#/channels/actionCommands/messages/actionCommand"
        }
      ]
    },
    "subscribeActionContracts": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/actionContracts"
      },
      "messages": [
        {
          "$ref": "#/channels/actionContracts/messages/actionContract"
        }
      ]
    },
    "subscribeActionProposals": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/actionProposals"
      },
      "messages": [
        {
          "$ref": "#/channels/actionProposals/messages/actionProposal"
        }
      ]
    },
    "subscribeActionResults": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/actionResults"
      },
      "messages": [
        {
          "$ref": "#/channels/actionResults/messages/actionResult"
        }
      ]
    },
    "subscribeAdapterHeartbeats": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/adapterHeartbeats"
      },
      "messages": [
        {
          "$ref": "#/channels/adapterHeartbeats/messages/adapterHeartbeat"
        }
      ]
    },
    "subscribeContextUpdates": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/contextUpdates"
      },
      "messages": [
        {
          "$ref": "#/channels/contextUpdates/messages/contextUpdate"
        }
      ]
    },
    "subscribeEventsDetected": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/eventsDetected"
      },
