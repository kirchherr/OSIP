{
  "asyncapi": "3.1.0",
  "channels": {
    "actionCommands": {
      "address": "omnisense.actions.commands.{target}",
      "description": "Approved Action Commands for adapter-facing targets.",
      "messages": {
        "actionCommand": {
          "$ref": "#/components/messages/actionCommand"
        }
      },
      "parameters": {
        "target": {
          "description": "Action target such as hvac.room or speaker.room."
        }
      },
      "x-osip-qos": {
        "adapter_notes": [],
        "deadline_ms": 20,
        "delivery": "reliable",
        "depth": 16,
        "durability": "volatile",
        "history": "keep_last",
        "max_latency_ms": 10,
        "priority": "critical"
      }
    },
    "actionContracts": {
      "address": "omnisense.actions.contracts",
      "description": "Available bounded Action Contracts.",
      "messages": {
        "actionContract": {
          "$ref": "#/components/messages/actionContract"
        }
      },
      "x-osip-qos": {
        "adapter_notes": [],
        "delivery": "reliable",
        "depth": 32,
        "durability": "transient_local",
        "history": "keep_last",
        "priority": "high"
      }
    },
    "actionProposals": {
      "address": "omnisense.actions.proposals",
      "description": "Bounded action proposals emitted by the Decision Runtime.",
      "messages": {
        "actionProposal": {
          "$ref": "#/components/messages/actionProposal"
        }
      },
      "x-osip-qos": {
        "adapter_notes": [],
        "deadline_ms": 100,
        "delivery": "reliable",
        "depth": 16,
        "durability": "volatile",
        "history": "keep_last",
        "max_latency_ms": 50,
        "priority": "high"
      }
    },
    "actionResults": {
      "address": "omnisense.actions.results.{action_id}",
      "description": "Action execution results by action id.",
      "messages": {
        "actionResult": {
          "$ref": "#/components/messages/actionResult"
        }
      },
      "parameters": {
        "action_id": {
          "description": "Action id from the originating contract."
        }
      },
      "x-osip-qos": {
        "adapter_notes": [],
        "deadline_ms": 100,
        "delivery": "reliable",
        "depth": 32,
        "durability": "volatile",
        "history": "keep_last",
        "max_latency_ms": 50,
        "priority": "high"
      }
    },
    "adapterHeartbeats": {
      "address": "omnisense.safety.heartbeats.{adapter_id}",
      "description": "Adapter heartbeat stream used by watchdogs and safe-state monitors.",
      "messages": {
        "adapterHeartbeat": {
          "$ref": "#/components/messages/adapterHeartbeat"
        }
      },
      "parameters": {
        "adapter_id": {
          "description": "Adapter id such as room_hvac_bridge or robot_arm_bridge."
        }
      },
      "x-osip-qos": {
        "adapter_notes": [],
        "deadline_ms": 20,
        "delivery": "best_effort",
        "depth": 1,
        "durability": "volatile",
        "history": "keep_last",
        "max_latency_ms": 10,
        "priority": "critical",
        "ttl_ms": 50
      }
    },
    "contextUpdates": {
      "address": "omnisense.context.updates.{room}",
      "description": "Fused context updates by room.",
      "messages": {
        "contextUpdate": {
          "$ref": "#/components/messages/contextUpdate"
        }
      },
      "parameters": {
        "room": {
          "description": "Room identifier."
        }
      },
      "x-osip-qos": {
        "adapter_notes": [],
        "deadline_ms": 50,
        "delivery": "best_effort",
        "depth": 1,
        "durability": "volatile",
        "history": "keep_last",
        "max_latency_ms": 25,
        "priority": "high",
        "ttl_ms": 100
      }
    },
    "eventsDetected": {
      "address": "omnisense.events.detected.{event_label}",
      "description": "Detected event stream for low-latency subscribers.",
      "messages": {
        "eventDetected": {
          "$ref": "#/components/messages/eventDetected"
        }
      },
      "parameters": {
        "event_label": {
          "description": "Detected event label."
        }
      },
      "x-osip-qos": {
        "adapter_notes": [],
        "deadline_ms": 20,
        "delivery": "best_effort",
        "depth": 1,
        "durability": "volatile",
        "history": "keep_last",
        "max_latency_ms": 10,
        "priority": "critical",
        "ttl_ms": 100
      }
    },
    "modelCapabilities": {
      "address": "omnisense.models.capabilities",
      "description": "Registered sensory model capability descriptors.",
      "messages": {
        "modelCapability": {
          "$ref": "#/components/messages/modelCapability"
        }
      },
      "x-osip-qos": {
        "adapter_notes": [
          "Adapters may retain the latest capability set for late joiners."
        ],
        "delivery": "reliable",
        "depth": 16,
        "durability": "transient_local",
        "history": "keep_last",
        "priority": "normal"
      }
    },
    "percepts": {
      "address": "omnisense.percepts.{modality}.{source_model}",
      "description": "Percept packets emitted by sensory models. Source model identifiers that contain dots expand into multiple topic segments on concrete transports.",
      "messages": {
        "perceptPacket": {
          "$ref": "#/components/messages/perceptPacket"
        }
      },
      "parameters": {
        "modality": {
          "description": "Percept modality such as audio, rgb, radar, or chemical."
        },
        "source_model": {
          "description": "Registered source model id."
        }
      },
      "x-osip-qos": {
        "adapter_notes": [
          "Physical-AI adapters should map this to low-latency sensor-data QoS."
        ],
        "deadline_ms": 10,
        "delivery": "best_effort",
        "depth": 1,
        "durability": "volatile",
        "history": "keep_last",
        "max_latency_ms": 10,
        "priority": "high",
        "ttl_ms": 50
      }
    },
    "profileSafetyCases": {
      "address": "omnisense.safety.profiles.{profile_id}.safe_states",
      "description": "Profile-level default safe-state and watchdog requirements.",
      "messages": {
        "profileSafetyCase": {
          "$ref": "#/components/messages/profileSafetyCase"
        }
      },
      "parameters": {
        "profile_id": {
          "description": "Application Profile id such as rooms or physical-ai."
        }
      },
      "x-osip-qos": {
        "adapter_notes": [
          "Adapters should load safe states before accepting action commands."
        ],
        "delivery": "reliable",
        "depth": 8,
        "durability": "transient_local",
        "history": "keep_last",
        "priority": "critical"
      }
    }
  },
  "components": {
    "messages": {
      "actionCommand": {
        "contentType": "application/json",
        "name": "action.command",
        "payload": {
          "$ref": "../schemas/action_command.schema.json"
        },
        "title": "action.command"
      },
      "actionContract": {
        "contentType": "application/json",
        "name": "action.contract",
        "payload": {
          "$ref": "../schemas/action_contract.schema.json"
        },
        "title": "action.contract"
      },
      "actionProposal": {
        "contentType": "application/json",
        "name": "action.proposal",
        "payload": {
          "$ref": "../schemas/action_proposal.schema.json"
        },
        "title": "action.proposal"
      },
      "actionResult": {
        "contentType": "application/json",
        "name": "action.result",
        "payload": {
          "$ref": "../schemas/action_result.schema.json"
        },
        "title": "action.result"
      },
      "adapterHeartbeat": {
        "contentType": "application/json",
        "name": "adapter.heartbeat",
        "payload": {
          "$ref": "../schemas/adapter_heartbeat.schema.json"
        },
        "title": "adapter.heartbeat"
      },
      "contextUpdate": {
        "contentType": "application/json",
        "name": "context.update",
        "payload": {
          "$ref": "../schemas/context_update.schema.json"
        },
        "title": "context.update"
      },
      "eventDetected": {
        "contentType": "application/json",
        "name": "event.detected",
        "payload": {
          "$ref": "../schemas/event_detected.schema.json"
        },
        "title": "event.detected"
      },
      "modelCapability": {
        "contentType": "application/json",
        "name": "model.capability",
        "payload": {
          "$ref": "../schemas/model_capability.schema.json"
        },
        "title": "model.capability"
      },
      "perceptPacket": {
        "contentType": "application/json",
        "name": "percept.packet",
        "payload": {
          "$ref": "../schemas/percept_packet.schema.json"
        },
        "title": "percept.packet"
      },
      "profileSafetyCase": {
        "contentType": "application/json",
        "name": "profile.safety_case",
        "payload": {
          "$ref": "../schemas/profile_safety_case.schema.json"
        },
        "title": "profile.safety_case"
      }
    }
  },
  "defaultContentType": "application/json",
  "id": "https://schemas.omnisense.dev/asyncapi/osip-0.1.0",
  "info": {
    "description": "Transport-agnostic event channels for OSIP v0.1. Concrete adapters such as in-memory bus, NATS, MQTT, or ROS 2/DDS map these channels to their native topic or subject syntax.",
    "title": "OmniSense Runtime OSIP Event API",
    "version": "0.1.0"
  },
  "operations": {
