{
  "$defs": {
    "DefaultSafeState": {
      "additionalProperties": false,
      "properties": {
        "max_transition_ms": {
          "anyOf": [
            {
              "$ref": "#/$defs/PositiveInt"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "requires_hardware_interlock": {
          "default": false,
          "title": "Requires Hardware Interlock",
          "type": "boolean"
        },
        "safe_state": {
          "$ref": "#/$defs/Label"
        },
        "target": {
          "$ref": "#/$defs/Label"
        },
        "triggers": {
          "items": {
            "$ref": "#/$defs/SafeStateTrigger"
          },
          "minItems": 1,
          "title": "Triggers",
          "type": "array"
        }
      },
      "required": [
        "target",
        "safe_state",
        "triggers"
      ],
      "title": "DefaultSafeState",
      "type": "object"
    },
    "Label": {
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$",
      "type": "string"
    },
    "PositiveInt": {
      "exclusiveMinimum": 0,
      "type": "integer"
    },
    "ProfileIdentifier": {
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z0-9_-]+)*$",
      "type": "string"
    },
    "SafeStateTrigger": {
      "enum": [
        "heartbeat_timeout",
        "context_stale",
        "bus_disconnect",
        "adapter_error",
        "manual_estop",
        "contract_violation",
        "sensor_dropout"
      ],
      "type": "string"
    },
    "TraceIdentifier": {
      "minLength": 1,
      "type": "string"
    }
  },
  "$id": "https://schemas.omnisense.dev/osip/0.1/profile_safety_case.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "correlation_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/TraceIdentifier"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "default_safe_states": {
      "items": {
        "$ref": "#/$defs/DefaultSafeState"
      },
      "minItems": 1,
      "title": "Default Safe States",
      "type": "array"
    },
    "heartbeat_timeout_ms": {
      "$ref": "#/$defs/PositiveInt"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "title": "Notes",
      "type": "array"
    },
    "profile_id": {
      "$ref": "#/$defs/ProfileIdentifier"
    },
    "safety_case_id": {
      "minLength": 1,
      "title": "Safety Case Id",
      "type": "string"
    },
    "schema_version": {
      "const": "osip/0.1",
      "default": "osip/0.1",
      "title": "Schema Version",
      "type": "string"
    },
    "stale_context_ms": {
      "$ref": "#/$defs/PositiveInt"
    },
    "trace_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/TraceIdentifier"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "type": {
      "const": "profile.safety_case",
      "default": "profile.safety_case",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "safety_case_id",
    "profile_id",
    "heartbeat_timeout_ms",
    "stale_context_ms",
    "default_safe_states"
  ],
  "title": "ProfileSafetyCase",
  "type": "object"
}
