{
  "$defs": {
    "Confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "type": "number"
    },
    "ContextEntity": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "$ref": "#/$defs/Confidence"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "state": {
          "anyOf": [
            {
              "$ref": "#/$defs/Identifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "type": {
          "$ref": "#/$defs/Identifier"
        },
        "uncertainty": {
          "anyOf": [
            {
              "$ref": "#/$defs/Uncertainty"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "zone": {
          "anyOf": [
            {
              "$ref": "#/$defs/Identifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "id",
        "type",
        "confidence"
      ],
      "title": "ContextEntity",
      "type": "object"
    },
    "ContextEvent": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "$ref": "#/$defs/Confidence"
        },
        "contradiction_refs": {
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          },
          "title": "Contradiction Refs",
          "type": "array"
        },
        "contradictions": {
          "items": {
            "$ref": "#/$defs/Label"
          },
          "title": "Contradictions",
          "type": "array"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/Label"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "evidence_refs": {
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "label": {
          "$ref": "#/$defs/Label"
        },
        "uncertainty": {
          "anyOf": [
            {
              "$ref": "#/$defs/Uncertainty"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "urgency": {
          "$ref": "#/$defs/Confidence"
        }
      },
      "required": [
        "label",
        "confidence",
        "urgency",
        "evidence"
      ],
      "title": "ContextEvent",
      "type": "object"
    },
    "CovarianceMatrix": {
      "additionalProperties": false,
      "properties": {
        "unit": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "values": {
          "items": {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          "minItems": 1,
          "title": "Values",
          "type": "array"
        },
        "variables": {
          "items": {
            "$ref": "#/$defs/Identifier"
          },
          "minItems": 1,
          "title": "Variables",
          "type": "array"
        }
      },
      "required": [
        "variables",
        "values"
      ],
      "title": "CovarianceMatrix",
      "type": "object"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "description": "Structured reference to the source evidence behind a context event.",
      "properties": {
        "claim_label": {
          "anyOf": [
            {
              "$ref": "#/$defs/Label"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "confidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/Confidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "modality": {
          "anyOf": [
            {
              "$ref": "#/$defs/Identifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_model": {
          "anyOf": [
            {
              "$ref": "#/$defs/Identifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "source_type": {
          "$ref": "#/$defs/EvidenceSourceType"
        },
        "timestamp": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timestamp"
        }
      },
      "required": [
        "source_type",
        "source_id"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "EvidenceSourceType": {
      "enum": [
        "percept.packet",
        "context.update",
        "event.detected",
        "action.result",
        "external"
      ],
      "type": "string"
    },
    "GlobalRisk": {
      "additionalProperties": false,
      "properties": {
        "comfort": {
          "$ref": "#/$defs/Confidence"
        },
        "maintenance": {
          "$ref": "#/$defs/Confidence"
        },
        "safety": {
          "$ref": "#/$defs/Confidence"
        }
      },
      "required": [
        "safety",
        "comfort",
        "maintenance"
      ],
      "title": "GlobalRisk",
      "type": "object"
    },
    "Identifier": {
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)*(_v[0-9]+)?$",
      "type": "string"
    },
    "Label": {
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$",
      "type": "string"
    },
    "PositiveInt": {
      "exclusiveMinimum": 0,
      "type": "integer"
    },
    "TraceIdentifier": {
      "minLength": 1,
      "type": "string"
    },
    "Uncertainty": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/Confidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "covariance": {
          "anyOf": [
            {
              "$ref": "#/$defs/CovarianceMatrix"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "distribution": {
          "anyOf": [
            {
              "$ref": "#/$defs/Identifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "Uncertainty",
      "type": "object"
    }
  },
  "$id": "https://schemas.omnisense.dev/osip/0.1/context_update.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "context_id": {
      "minLength": 1,
      "title": "Context Id",
      "type": "string"
    },
    "correlation_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/TraceIdentifier"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "entities": {
      "items": {
        "$ref": "#/$defs/ContextEntity"
      },
      "title": "Entities",
      "type": "array"
    },
    "events": {
      "items": {
        "$ref": "#/$defs/ContextEvent"
      },
      "title": "Events",
      "type": "array"
    },
    "global_risk": {
      "$ref": "#/$defs/GlobalRisk"
    },
    "room": {
      "$ref": "#/$defs/Identifier"
    },
    "schema_version": {
      "const": "osip/0.1",
      "default": "osip/0.1",
      "title": "Schema Version",
      "type": "string"
    },
    "time_window_ms": {
      "$ref": "#/$defs/PositiveInt"
    },
    "timestamp": {
      "format": "date-time",
      "title": "Timestamp",
      "type": "string"
    },
    "trace_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/TraceIdentifier"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "type": {
      "const": "context.update",
      "default": "context.update",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "context_id",
    "timestamp",
    "time_window_ms",
    "room",
    "global_risk"
  ],
  "title": "ContextUpdate",
  "type": "object"
}
